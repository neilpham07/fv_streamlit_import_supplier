# Copy file này thành .env và điền giá trị thực — KHÔNG commit file .env lên git

# Database — dùng user riêng chỉ có quyền SELECT/INSERT/UPDATE, KHÔNG dùng postgres superuser
DATABASE_URL=postgresql://app_user:STRONG_PASSWORD@your-db-host:5432/supplychain_pro

# App login — đặt mật khẩu mạnh (>= 12 ký tự, chữ hoa + số + ký tự đặc biệt)
APP_USERNAME=your_username
APP_PASSWORD=YourStr0ng!Password
